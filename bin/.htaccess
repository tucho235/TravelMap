# Denegar todo acceso web al directorio bin/
# Los scripts aquí son exclusivos de CLI — no deben ser alcanzables por ningún servidor web.
# Ver también: docs/BACKUP_CLI.md para la configuración recomendada de nginx.

<IfModule mod_authz_core.c>
    # Apache 2.4+
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order deny,allow
    Deny from all
</IfModule>

<FilesMatch ".*">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
